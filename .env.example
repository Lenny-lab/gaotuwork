# 飞书应用凭证(必填,飞书开发者后台 → 凭证与基础信息)
APP_ID=cli_xxxxxxxxxxxx
APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书 OpenAPI 域名(国内版固定这个,海外版改 https://open.larksuite.com)
FEISHU_HOST=https://open.feishu.cn

# 事件订阅相关(机器人能力 → 事件订阅 → 加密策略选"加密"才需要)
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# 多维表格(用多维表格自动化时填)
# 飞书 URL: https://xxx.feishu.cn/base/<APP_TOKEN>?table=<TABLE_ID>
BITABLE_APP_TOKEN=
BITABLE_TABLE_ID=
