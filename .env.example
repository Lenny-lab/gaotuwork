# 飞书应用凭证(必填,飞书开发者后台 → 凭证与基础信息)
APP_ID=cli_xxxxxxxxxxxx
APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书 OpenAPI 域名(国内版固定这个,海外版改 https://open.larksuite.com)
FEISHU_HOST=https://open.feishu.cn
PUBLIC_BASE_URL=https://classmind-feishu.onrender.com

# 登录 Session（生产环境必须使用随机长字符串，并开启 Secure Cookie）
FLASK_SECRET_KEY=replace-with-a-long-random-secret
SESSION_COOKIE_SECURE=1
# 线上必须为 0：角色只能由真实飞书账号决定；本地比赛演示可临时设为 1
DEMO_LOGIN_ENABLED=0

# 首次真实登录自动识别：在部署平台的 Secret 环境变量中填写，不要提交真实手机号。
# 格式为 ClassMind 业务用户 ID -> 飞书注册手机号。系统仅用它调用手机号换 Open ID 接口。
FEISHU_MOBILE_BINDINGS={"U_S001":"student-mobile","U_T001":"teacher-mobile"}

# 事件订阅相关(机器人能力 → 事件订阅 → 加密策略选"加密"才需要)
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# 多维表格(用多维表格自动化时填)
# 飞书 URL: https://xxx.feishu.cn/base/<APP_TOKEN>?table=<TABLE_ID>
BITABLE_APP_TOKEN=
BITABLE_TABLE_ID=
